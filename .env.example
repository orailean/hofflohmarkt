# Port the app is published on (host side)
PORT=8000

# Port uvicorn listens on INSIDE the container (and the health check target).
# Usually you only need to change PORT; change this when the in-container
# port itself must differ (e.g. platform conventions like 8080).
APP_PORT=8000

# Docker image tag used by docker compose
IMAGE_TAG=latest

# Directories for persistent data — all written to /data (mounted volume in Docker).
# Change only if you need to redirect storage elsewhere.
HOFFROUTE_JOBS_DIR=/data/jobs
HOFFROUTE_CALIB_CACHE_DIR=/data/calibration_cache
HOFFROUTE_ROUTE_CACHE_DIR=/data/route_cache

# Users allowed to open and submit manual calibration.
# Comma-separated username:password entries, or a JSON object.
HOFFROUTE_MANUAL_USERS=admin:change-me

# Secret used to sign the manual-calibration login cookie.
# Set to a long random value in production.
HOFFROUTE_AUTH_SECRET=change-me-to-a-long-random-secret

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Log level for all output (stdout + file). One of: DEBUG INFO WARNING ERROR
HOFFROUTE_LOG_LEVEL=INFO

# Path to the rotating log file.
# Set to an empty string to disable file logging entirely.
HOFFROUTE_LOG_FILE=/data/logs/hoffroute.log

# Maximum size of one log file before it is rotated (bytes).
# Default: 10485760 (10 MB)
HOFFROUTE_LOG_MAX_BYTES=10485760

# Number of compressed (.gz) rotated log files to keep alongside the live one.
# Default: 5  →  up to ~55 MB total log storage at default sizes.
HOFFROUTE_LOG_BACKUP_COUNT=5
