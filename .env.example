# Port the app is published on (host side)
PORT=8000

# Port uvicorn listens on INSIDE the container (and the health check target).
# Usually you only need to change PORT; change this when the in-container
# port itself must differ (e.g. platform conventions like 8080).
APP_PORT=8000

# Docker image tag used by docker compose
IMAGE_TAG=latest

# Where job files (uploaded PDFs, rendered pages, results) are stored
# inside the container. The compose file mounts a named volume here.
HOFFROUTE_JOBS_DIR=/data/jobs

# Users allowed to open and submit manual calibration.
# Comma-separated username:password entries, or a JSON object.
HOFFROUTE_MANUAL_USERS=admin:change-me

# Secret used to sign the manual-calibration login cookie.
# Set to a long random value in production.
HOFFROUTE_AUTH_SECRET=change-me-to-a-long-random-secret
